#!/opt/homebrew/bin/gawk -f
#
# Convert hmmersearch --domtblout output to GFF3 format
#
# 1. HMMER v3.4 domtblout format reference: <http://eddylab.org/software/hmmer/Userguide.pdf> (page 70)
# 2. Target sequences are assumed come from a translated genome using the Easel tool esl-translate,
#    tool manual and FASTA header format reference: <http://eddylab.org/software/hmmer/Userguide.pdf> (page 202)
# GFF3 format reference: <https://github.com/The-Sequence-Ontology/Specifications/blob/master/gff3.md>
#
# Usage: ./hmmsearch_domtblout2gff.awk hmmsearch.domtblout > output.gff3

BEGIN {
    print "##gff-version 3"
    # Some metadata just in case
    print "# This gff3 file was generated from hmmsearch --domtblout output with hmmsearch_domtblout2gff.awk"
    print "# Any relevant information from the original domtblout file can be found at the end of the file"
    # Fromat time ISO 8601
    date = strftime("%Y-%m-%dT%H:%M:%S%z")
    print "# Timestamp: " date
}

# We only skip 3 lines, the first two header lines and the separator line
# We do not want to skip all line starting with '#' because the lines in the
# bottom part of the file starting with '#' contain important metadata.

/^#/ {
    if (NR == 1 || NR == 2 || NR == 3) {
        next
    }
    print $0
}

!/^#/ {
    # Parse the relevant fields from the nhmmer --domtblout output
    target_name             = $1
    _target_accession       = $2
    _target_length           = $3
    query_name              = $4
    query_accession         = $5
    query_length            = $6
    _full_sequence_e_value   = $7
    _full_sequence_score     = $8
    _full_sequence_bias      = $9
    _current_domain_number   = $10
    _total_domain_number     = $11
    _domain_c_e_value        = $12
    domain_i_e_value        = $13
    domain_score            = $14
    domain_bias             = $15
    hmm_from                = $16
    hmm_to                  = $17
    sequence_ali_from       = $18
    sequence_ali_to         = $19
    sequence_env_from       = $20
    sequence_env_to         = $21
    accuracy                = $22
    # From now on, they are all target description field (23th field).
    # Still, the FASTA header has been generated by esl-translate.
    easel_source            = $23
    easel_coords            = $24
    easel_lenght            = $25
    easel_frame             = $26

    # Extract the actual fields from the FASTA header generated by esl-translate
    split(easel_source, easel_source_arr, "=")
    orf_source = easel_source_arr[2]
    split(easel_coords, easel_coords_arr, "=")
    orf_coords = easel_coords_arr[2]
    split(orf_coords, orf_coords_arr, /\.\./)
    orf_start = orf_coords_arr[1]
    orf_end = orf_coords_arr[2]
    split(easel_lenght, easel_lenght_arr, "=")
    orf_length = easel_lenght_arr[2]
    split(easel_frame, easel_frame_arr, "=")
    orf_frame = easel_frame_arr[2]

    # WARNING: Test the outcome if the following block is edited:
    if (orf_frame < 4) {
        gff_strand = "+"
        nt_start = orf_start + (sequence_env_from * 3)
        nt_end = orf_start + (sequence_env_to * 3)
    } else if (orf_frame > 3) {
        gff_strand = "-"
        nt_start = orf_end + (sequence_env_from * 3)
        nt_end = orf_end + (sequence_env_to * 3)
    } else {
        # Stop with error if the strand information is not valid and exit with non-zero status
        print "Error: Invalid strand information for ORF " orf_name " in line " NR > "/dev/stderr"
        exit 1
    }

    gff_seqid   = orf_source
    gff_source  = "hmmsearch"
    gff_type    = "hmmsearch_hit"
    gff_start   = nt_start
    gff_end     = nt_end
    gff_score   = domain_score
    gff_strand  = gff_strand
    gff_phase   = "."


    # Construct the attributes field
    # Using a semicolon-separated list of key=value pairs
    # Including relevant information from the nhmmer output
    gff_attributes =    "ID=" target_name";" \
                        "Query=" query_name ";" \
                        "QueryAccession=" query_accession ";" \
                        "QueryLength=" query_length ";" \
                        "iEvalue=" domain_i_e_value ";" \
                        "DomainScore=" domain_score ";" \
                        "DomainBias=" domain_bias ";" \
                        "OrfStart=" orf_start ";" \
                        "OrfEnd=" orf_end ";" \
                        "HMMFrom=" hmm_from ";" \
                        "HMMTo=" hmm_to ";" \
                        "SequenceAliFrom=" sequence_ali_from ";" \
                        "SequenceAliTo=" sequence_ali_to ";" \
                        "SequenceEnvFrom=" sequence_env_from ";" \
                        "SequenceEnvTo=" sequence_env_to ";" \
                        "Accuracy=" accuracy

    # Print the GFF3 formatted line
    #   GFF3 fields: seqid, source, type, start, end, score, strand, phase, attributes
    print gff_seqid "\t" gff_source "\t" gff_type "\t" gff_start "\t" gff_end "\t" gff_score "\t" gff_strand "\t" gff_phase "\t" gff_attributes
}




